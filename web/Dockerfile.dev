# Recipes web development image.
#
# Keeps Node dependencies and Vite/React Router dev tooling available for
# DevSpace source sync and browser hot module reload.

FROM node:20-alpine

WORKDIR /workspace/web

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

ENV HOST=0.0.0.0 \
    PORT=3000
EXPOSE 3000

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
