# Copy this file to .env in the same directory (backend/.env) before running the API.
# From backend/: cp .env.example .env
#
# The API loads, in order: ./.env then backend/.env (second helps if cwd is repo root).

# HTTP bind address (optional — default is localhost:4000)
# API_ADDR=localhost:4000

# PostgreSQL (used by recipes-repo when wired in)
DB_HOST=localhost
DB_PORT=5432
DB_USER=recipes
DB_PASSWORD=recipes123
DB_NAME=recipes
